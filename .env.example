# AdSparkr Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Configuration (Required for AI ad generation)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration (Optional - for data persistence)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Instagram API Configuration (Optional - for Instagram posting)
VITE_INSTAGRAM_CLIENT_ID=your_instagram_client_id
VITE_INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# TikTok API Configuration (Optional - for TikTok posting)
VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key
VITE_TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Stripe Configuration (Optional - for payments, if not using x402)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Development Settings
VITE_APP_ENV=development
VITE_DEBUG_MODE=true
